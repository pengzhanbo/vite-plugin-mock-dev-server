{
  "name": "mock-dev-server-monorepo",
  "type": "module",
  "version": "2.1.1",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "author": "pengzhanbo <q942450674@outlook.com> (https://github.com/pengzhanbo)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pengzhanbo/vite-plugin-mock-dev-server"
  },
  "scripts": {
    "build": "pnpm build:js && pnpm build:ui",
    "build:js": "pnpm -F vite-plugin-mock-dev-server build",
    "build:ui": "vite build vite-plugin-mock-dev-server/ui",
    "dev": "pnpm build:ui && pnpm dev:js",
    "dev:js": "pnpm -F example dev",
    "dev:ui": "vite build vite-plugin-mock-dev-server/ui --watch",
    "example:build": "pnpm -F example build",
    "docs:build": "pnpm -F docs docs:build",
    "docs:dev": "pnpm -F docs docs:dev",
    "docs:preview": "pnpm -F docs docs:preview",
    "lint": "eslint .",
    "test": "vitest",
    "release:changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "release:publish": "pnpm -r publish",
    "release": "bumpp package.json {vite-plugin-mock-dev-server,docs,example}/package.json --execute=\"pnpm release:changelog\" --commit --all --push --tag"
  },
  "devDependencies": {
    "@pengzhanbo/eslint-config-svelte": "catalog:dev",
    "@sveltejs/vite-plugin-svelte": "catalog:ui",
    "@tailwindcss/vite": "catalog:ui",
    "@tsconfig/svelte": "catalog:ui",
    "@types/co-body": "catalog:dev",
    "@types/cors": "catalog:dev",
    "@types/debug": "catalog:dev",
    "@types/formidable": "catalog:dev",
    "@types/is-core-module": "catalog:dev",
    "@types/mime-types": "catalog:dev",
    "@types/node": "catalog:dev",
    "@types/picomatch": "catalog:dev",
    "@types/ws": "catalog:dev",
    "bumpp": "catalog:dev",
    "clsx": "catalog:ui",
    "conventional-changelog-cli": "catalog:dev",
    "eslint": "catalog:dev",
    "ofetch": "catalog:ui",
    "svelte": "catalog:ui",
    "tailwindcss": "catalog:ui",
    "tsdown": "catalog:dev",
    "typescript": "catalog:dev",
    "vitest": "catalog:dev"
  }
}
